<?xml version="1.0"?>
<robot name="bracket_arm">

  <material name="silver"><color rgba="0.5 0.5 0.5 1"/></material>
  <material name="red">   <color rgba="1 0 0 1"/></material>
  <material name="green"> <color rgba="0 1 0 1"/></material>
  <material name="blue">  <color rgba="0 0 1 1"/></material>
  <material name="yellow"><color rgba="1 1 0 1"/></material>
  <material name="orange"><color rgba="1 0.5 0 1"/></material>
  <material name="white"> <color rgba="1 1 1 1"/></material>

  <!-- Feste Grundplatte -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.1 0.1 0.02"/></geometry>
      <material name="silver"/>
    </visual>
  </link>

  <!-- Servo 0: dreht den ganzen Arm um die vertikale Achse -->
  <joint name="joint_0" type="revolute">
    <parent link="base_link"/>
    <child link="turret_link"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- Drehbarer Sockel (82mm hoch) bis zum Schulter-Servo -->
  <link name="turret_link">
    <visual>
      <geometry><cylinder length="0.082" radius="0.03"/></geometry>
      <origin xyz="0 0 0.041"/>
      <material name="red"/>
    </visual>
  </link>

  <!-- Servo 1: Schulter - dreht den Oberarm -->
  <joint name="joint_1" type="revolute">
    <parent link="turret_link"/>
    <child link="upper_arm_link"/>
    <!-- 0° = horizontal, daher -90° Offset -->
    <origin xyz="0 0 0.082" rpy="0 -1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- Oberarm: 98mm, Schulter bis Ellenbogen -->
  <link name="upper_arm_link">
    <visual>
      <!-- geometry><cylinder length="0.098" radius="0.02"/></geometry -->
      <geometry><box size="0.04 0.02 0.098"/></geometry>
      <origin xyz="0 0 0.049"/>
      <material name="green"/>
    </visual>
  </link>

  <!-- Servo 2: Ellenbogen - dreht den Unterarm (umgekehrt eingebaut) -->
  <joint name="joint_2" type="revolute">
      <parent link="upper_arm_link"/>
      <child link="forearm_link"/>
      <origin xyz="0 0 0.098" rpy="0 1.5708 0"/>
      <!-- Drehrichtung. Umgekehrt eingebaut, daher -1. -->
      <axis xyz="0 -1 0"/>
      <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- Unterarm: 66mm, Ellenbogen bis Handgelenk -->
  <link name="forearm_link">
    <visual>
      <geometry><cylinder length="0.066" radius="0.02"/></geometry>
      <origin xyz="0 0 0.033"/>
      <material name="blue"/>
    </visual>
  </link>

  <!-- Servo 3: Handgelenk-Neigung -->
  <joint name="joint_3" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 0.066" rpy="0 -1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- Handgelenk: 103mm bis Greifer-Gelenk -->
  <link name="wrist_link">
    <visual>
      <geometry><cylinder length="0.103" radius="0.015"/></geometry>
      <origin xyz="0 0 0.0515"/>
      <material name="yellow"/>
    </visual>
  </link>

  <!-- Servo 4: Handgelenk-Rotation (dreht um Längsachse) -->
  <joint name="joint_4" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.103" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- Greifer-Basis -->
  <link name="gripper_base_link">
    <visual>
      <geometry><box size="0.03 0.03 0.02"/></geometry>
      <origin xyz="0 0 0.01"/>
      <material name="orange"/>
    </visual>
  </link>

  <!-- Servo 5: Greifer öffnen/schliessen -->

  <!-- Linker Finger -->
  <joint name="joint_5" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="gripper_finger_left_link"/>
    <!--origin xyz="0 0 0.02" rpy="0 0.785 0"/ -->
    <origin xyz="-0.01 0.01 0.0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- Linker Finger: Greiferspitze: 70mm -->
  <link name="gripper_finger_left_link">
    <visual>
      <geometry><box size="0.02 0.01 0.07"/></geometry>
      <origin xyz="0 0 0.035"/>
      <material name="white"/>
    </visual>
  </link>

  <!-- Rechter Finger - gespiegelt, mimic von joint_5 -->
  <joint name="joint_5_mimic" type="revolute">
      <parent link="gripper_base_link"/>
      <child link="gripper_finger_right_link"/>
      <origin xyz="0.01 0.01 0.0" rpy="0 0 0"/>
      <axis xyz="0 -1 0"/>
      <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
      <mimic joint="joint_5" multiplier="-1" offset="0"/>
  </joint>

  <!-- Rechter Finger: Greiferspitze: 70mm -->
  <link name="gripper_finger_right_link">
      <visual>
          <geometry><box size="0.02 0.01 0.07"/></geometry>
          <origin xyz="0 0 0.035"/>
          <material name="silver"/>
      </visual>
  </link>

</robot>
