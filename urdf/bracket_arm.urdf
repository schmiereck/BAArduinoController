<?xml version="1.0"?>
<robot name="bracket_arm">

  <material name="silver"><color rgba="0.7 0.7 0.7 1"/></material>

  <link name="base_link">
    <visual><geometry><box size="0.1 0.1 0.02"/></geometry></visual>
  </link>

  <joint name="joint_0" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.082" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="shoulder_link">
    <visual><geometry><cylinder length="0.098" radius="0.02"/></geometry><origin xyz="0 0 0.049"/></visual>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <!-- rpy: 0° ist am roboter horizontal -->
    <origin xyz="0 0 0.098" rpy="0 -1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <link name="upper_arm_link">
    <visual><geometry><cylinder length="0.066" radius="0.02"/></geometry><origin xyz="0 0 0.033"/></visual>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.066" rpy="0 -1.5708 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <link name="forearm_link">
    <visual><geometry><cylinder length="0.103" radius="0.02"/></geometry><origin xyz="0 0 0.0515"/></visual>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0 0 0.103" rpy="0 -1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="0" effort="10" velocity="1.0"/>
  </joint>

  <link name="wrist_pitch_link">
    <visual><geometry><sphere radius="0.02"/></geometry></visual>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="gripper_base_link">
    <visual><geometry><box size="0.03 0.03 0.02"/></geometry></visual>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="gripper_tip_link"/>
    <origin xyz="0 0 0.070" rpy="0 0.785 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="gripper_tip_link">
    <visual><geometry><box size="0.01 0.01 0.02"/></geometry></visual>
  </link>

</robot>
